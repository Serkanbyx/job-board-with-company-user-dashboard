# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/jobboard

# JWT — Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_min_32_chars_here
# Access token lifetime (default 1h). Accepts ms-style strings: 15m, 1h, 2h, 1d, etc.
ACCESS_TOKEN_TTL=1h
# Refresh token: 7 days by default, 30 days when "Remember me" is selected (managed in code)

# CORS
CORS_ORIGIN=http://localhost:5173

# Cloudinary — Get credentials from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (SMTP) — Optional, emails disabled if not configured
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=JobBoard <noreply@jobboard.com>

# Client URL (for email links)
CLIENT_URL=http://localhost:5173
